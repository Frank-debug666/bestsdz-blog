---
import type { CollectionEntry } from 'astro:content';
import { getPostPlacement } from '../learning-path';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const placement = getPostPlacement(post.id);
const date = post.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="post-row" data-post-row data-post-id={post.id}>
  <a class="post-row-media" href={`/posts/${post.id}/`}>
    <span class="post-row-media-frame">
      <img
        class="post-row-thumb"
        src={post.data.cover ?? '/writing-desk.png'}
        alt={post.data.coverAlt ?? post.data.title}
        width="1680"
        height="1120"
        loading="lazy"
      />
    </span>
  </a>

  <div class="post-row-main">
    <div class="post-row-meta-line">
      <time class="post-meta" datetime={post.data.pubDate.toISOString()}>{date}</time>
      {placement.stage && <span class="post-level">{placement.stage.level}</span>}
    </div>
    <div class="post-row-copy">
      <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
      <p>{post.data.description}</p>
    </div>
  </div>

  <div class="post-row-side">
    <div class="post-tags" aria-label="标签">
      {post.data.tags.map((tag) => <a class="tag soft" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
    </div>
    <a class="post-row-link" href={`/posts/${post.id}/`}>阅读全文</a>
  </div>
</article>
