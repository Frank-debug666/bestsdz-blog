---
import '../styles/global.css';
import { siteConfig } from '../site.config';
import ViewCounter from '../components/ViewCounter.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = siteConfig.description,
  image = '/images/hero-qingdao-harbor.jpg',
  type = 'website',
  structuredData,
} = Astro.props;

const siteTitle = siteConfig.name;
const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const currentPath = Astro.url.pathname;
const bodyClass = currentPath === '/' ? 'home-page' : 'inner-page';
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const cloudflareBeacon = siteConfig.cloudflareAnalyticsToken
  ? JSON.stringify({ token: siteConfig.cloudflareAnalyticsToken })
  : '';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#11161d" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={siteConfig.author.name} />
    <meta name="generator" content="Astro" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/logo-route-star.svg?v=20260713-route-star" />
    <link rel="icon" type="image/png" href="/logo-route-star-512.png?v=20260713-route-star" />
    <link rel="apple-touch-icon" href="/logo-route-star-512.png?v=20260713-route-star" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${siteTitle} RSS`} href="/rss.xml" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {cloudflareBeacon && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={cloudflareBeacon}
        is:inline
      ></script>
    )}
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
    )}
    <title>{pageTitle}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <header class="site-header">
      <div class="shell header-frame">
        <nav class="nav" aria-label="主导航">
          <a class="brand" href="/">
            <img class="brand-logo" src="/logo-route-star.svg?v=20260713-route-star" alt="" width="40" height="40" aria-hidden="true" />
            <span class="brand-text">{siteTitle}</span>
          </a>
          <div class="nav-links">
            <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>首页</a>
            <a href="/start/" aria-current={currentPath === '/start/' ? 'page' : undefined}>新手</a>
            <a href="/ai-roadmap/" aria-current={currentPath === '/ai-roadmap/' ? 'page' : undefined}>路线</a>
            <a href="/videos/" aria-current={currentPath === '/videos/' ? 'page' : undefined}>视频</a>
            <a href="/glossary/" aria-current={currentPath.startsWith('/glossary') ? 'page' : undefined}>词典</a>
            <a href="/posts/" aria-current={currentPath.startsWith('/posts') ? 'page' : undefined}>文章</a>
            <a href="/search/" aria-current={currentPath === '/search/' ? 'page' : undefined}>搜索</a>
            <a href="/about/" aria-current={currentPath === '/about/' ? 'page' : undefined}>关于</a>
            <a href="/rss.xml">订阅</a>
          </div>
        </nav>
      </div>
    </header>
    <div id="main-content">
      <slot />
    </div>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <div>
          <strong>{siteTitle}</strong>
          <p>记录旅途、生活与技术笔记，把值得停留的瞬间慢慢写下来。</p>
        </div>
        <div class="footer-meta">
          <ViewCounter />
          <span>© {new Date().getFullYear()} {siteTitle}</span>
          <span>Astro · Markdown · RSS · Cloudflare Pages</span>
        </div>
      </div>
    </footer>
  </body>
</html>
