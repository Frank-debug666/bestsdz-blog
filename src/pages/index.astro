---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostRow from '../components/PostRow.astro';
import ProjectSpotlight from '../components/ProjectSpotlight.astro';
import {
  contentSections,
  futureStages,
  getPostPlacement,
  graduationProjects,
  learningStages,
} from '../learning-path';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...recent] = posts;
const videoCount = posts.filter((post) => post.body?.includes('/videos/')).length;
const publishedLessonCount = contentSections.reduce((sum, section) => sum + section.postIds.length, 0);
const featuredDate = featured?.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const productPaths = [
  {
    number: '01',
    title: '我是零基础',
    description: '从什么是 AI、机器学习任务、数据集和评价指标开始，不先硬啃公式。',
    href: '/start/',
  },
  {
    number: '02',
    title: '我想补机器学习',
    description: '从第 21 篇开始，用传统机器学习把数据、训练、评估和模型选择走通。',
    href: '/ai-roadmap/#traditional-ml',
  },
  {
    number: '03',
    title: '我想做项目',
    description: '进入中文文本分类、PyTorch 深度学习项目和后续 RAG / Dify / 部署路线。',
    href: '/ai-roadmap/#text-classification',
  },
];

const activeStages = learningStages.filter((stage) => stage.status !== '规划中');
const nextFutureStages = futureStages.slice(0, 4);
const currentStage = activeStages[activeStages.length - 1];
const featuredPlacement = featured ? getPostPlacement(featured.id) : undefined;
const roadmapCards = contentSections.slice(0, 4);
const videoHighlights = posts
  .filter((post) => post.body?.includes('/videos/'))
  .slice(0, 3)
  .map((post) => ({
    post,
    placement: getPostPlacement(post.id),
  }));
---

<BaseLayout title="去你想去的地方">
  <main class="home-main home-version home-version-new academy-home">
    <section class="academy-hero">
      <img
        class="academy-backdrop"
        src="/images/hero-qingdao-harbor.jpg"
        alt="晴朗天空下的海滨城市、港湾、楼宇和远处岛屿。"
        width="2560"
        height="1436"
      />

      <div class="shell academy-hero-grid">
        <div class="academy-copy">
          <span class="academy-label">AI Learning Roadmap</span>
          <h1><span>从 0 开始，</span><span>把 AI 学成</span><span>一条清楚的路线</span></h1>
          <p>
            每一课都回答一个具体问题：先理解概念，再看代码，最后用视频把思路串起来。这里不是堆文章，而是一张会持续生长的 AI 学习地图。
          </p>
          <div class="academy-actions">
            <a class="button light" href="/start/">从第一课开始</a>
            <a class="button ghost" href="/ai-roadmap/">查看学习路线</a>
            <button class="button ghost home-version-toggle" type="button" data-home-version-toggle>
              回到旧版
            </button>
          </div>
        </div>

        {featured && (
          <article class="academy-current-card">
            <span class="academy-card-kicker">
              当前更新
              {featuredPlacement?.lessonLabel && ` · 第 ${featuredPlacement.lessonLabel} 课`}
            </span>
            <h2><a href={`/posts/${featured.id}/`}>{featured.data.title}</a></h2>
            <p>{featured.data.description}</p>
            <div class="academy-pill-row">
              {featured.data.tags.slice(0, 3).map((tag) => (
                <a class="academy-pill" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
              ))}
            </div>
          </article>
        )}
      </div>
    </section>

    <section class="shell academy-overview" aria-labelledby="academy-overview-title">
      <div class="academy-section-heading">
        <div>
          <span class="academy-label dark">Learning Roadmap</span>
          <h2 id="academy-overview-title">先把地图看清楚，再一课一课往前走</h2>
        </div>
        <a class="button secondary" href="/ai-roadmap/">完整路线</a>
      </div>

      <div class="academy-stage-grid">
        {roadmapCards.map((section, index) => (
          <a class="academy-stage-card" href="/ai-roadmap/">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
            <strong>{section.postIds.length} 篇内容 · {section.level}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="shell academy-board" aria-labelledby="academy-board-title">
      <div class="academy-route-panel">
        <div class="academy-section-heading compact">
          <div>
            <span class="academy-label dark">Course Map</span>
            <h2 id="academy-board-title">当前学习进度</h2>
          </div>
        </div>

        <dl class="academy-stats" aria-label="内容规模">
          <div>
            <dt>{posts.length}</dt>
            <dd>篇公开文章</dd>
          </div>
          <div>
            <dt>{videoCount}</dt>
            <dd>节配套视频</dd>
          </div>
          <div>
            <dt>{learningStages.length}</dt>
            <dd>个学习阶段</dd>
          </div>
        </dl>

        <div class="academy-route-list">
          {activeStages.map((stage) => (
            <a href={`/ai-roadmap/#${stage.id}`}>
              <span>{stage.number}</span>
              <strong>{stage.title}</strong>
              <em>{stage.status}</em>
            </a>
          ))}
        </div>
      </div>

      <div class="academy-video-panel">
        <div class="academy-section-heading compact">
          <div>
            <span class="academy-label dark">Video Lessons</span>
            <h2>配套视频</h2>
          </div>
          <a class="button secondary" href="/videos/">全部视频</a>
        </div>

        <div class="academy-video-list">
          {videoHighlights.map(({ post, placement }) => (
            <a class="academy-video-item" href={`/posts/${post.id}/`}>
              <span class="academy-video-number">{placement.lessonLabel ?? 'NEW'}</span>
              <span>
                <strong>{post.data.title}</strong>
                <em>{placement.stage?.title ?? currentStage?.title ?? 'AI 学习路线'}</em>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ProjectSpotlight variant="academy" headingId="echo-project-academy-title" />

    <section class="shell section article-section academy-latest">
      <div class="section-heading">
        <div>
          <h2>最新文章</h2>
          <p>继续沿着学习路线更新，文章和视频会尽量保持一一对应。</p>
        </div>
        <a class="button secondary" href="/posts/">全部文章</a>
      </div>
      <div class="post-list">
        {recent.slice(0, 5).map((post) => <PostRow post={post} />)}
      </div>
    </section>
  </main>

  <main class="home-main home-version home-version-legacy">
    <section class="hero-scene">
      <img
        class="hero-backdrop"
        src="/images/hero-qingdao-harbor.jpg"
        alt="晴朗天空下的海滨城市、港湾、楼宇和远处岛屿。"
        width="2560"
        height="1436"
      />

      <div class="shell hero-frame">
        <div class="hero-copy">
          <h1><span>去你想去</span><span>的地方</span></h1>
          <p>记录所思所想、旅行见闻、生活点滴与技术笔记。</p>
          <div class="hero-actions">
            <a class="button light" href="/start/">新手从这里开始</a>
            <a class="button ghost" href="/videos/">视频中心</a>
            <button class="button ghost home-version-toggle" type="button" data-home-version-toggle>
              切换新版
            </button>
          </div>
        </div>

        {featured && (
          <article class="featured-story">
            <div class="featured-media">
              <img
                class="featured-thumb"
                src={featured.data.cover ?? '/writing-desk.png'}
                alt={featured.data.coverAlt ?? featured.data.title}
                width="1680"
                height="1120"
              />
            </div>
            <div class="featured-content">
              <span class="featured-kicker">最近更新</span>
              <h2><a href={`/posts/${featured.id}/`}>{featured.data.title}</a></h2>
              <p>{featured.data.description}</p>
              <div class="featured-meta">
                <time datetime={featured.data.pubDate.toISOString()}>{featuredDate}</time>
                {featured.data.tags.slice(0, 2).map((tag) => (
                  <a class="tag dark" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
                ))}
              </div>
            </div>
          </article>
        )}
      </div>
    </section>

    <section class="shell product-overview" aria-labelledby="product-overview-title">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Learning System</span>
          <h2 id="product-overview-title">先选入口，再沿路线往前走</h2>
          <p>这个站不是单纯文章列表，而是一套从零基础、原理、代码、项目到部署的 AI 学习系统。</p>
        </div>
        <a class="button secondary" href="/search/">搜索内容</a>
      </div>

      <dl class="metric-strip" aria-label="内容规模">
        <div>
          <dt>{posts.length}</dt>
          <dd>篇公开文章</dd>
        </div>
        <div>
          <dt>{videoCount}</dt>
          <dd>节配套视频</dd>
        </div>
        <div>
          <dt>{learningStages.length}</dt>
          <dd>个学习阶段</dd>
        </div>
        <div>
          <dt>{publishedLessonCount}</dt>
          <dd>篇路线内容</dd>
        </div>
      </dl>

      <div class="product-path-grid">
        {productPaths.map((path) => (
          <a class="product-path-card" href={path.href}>
            <span>{path.number}</span>
            <h3>{path.title}</h3>
            <p>{path.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="shell learning-system-preview" aria-labelledby="learning-system-preview-title">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Course Map</span>
          <h2 id="learning-system-preview-title">这条路线会走到哪里</h2>
          <p>路线从 AI 入门与 PyTorch 基础开始，随后进入传统机器学习、文本分类、PyTorch 深化和后续工程化路线。</p>
        </div>
        <a class="button secondary" href="/ai-roadmap/">完整路线</a>
      </div>

      <div class="route-preview-grid">
        <div class="route-preview-panel">
          <h3>当前主线</h3>
          {activeStages.map((stage) => (
            <a href={`/ai-roadmap/#${stage.id}`}>
              <span>{stage.number}</span>
              <strong>{stage.title}</strong>
              <em>{stage.status}</em>
            </a>
          ))}
        </div>
        <div class="route-preview-panel">
          <h3>后续进阶</h3>
          {nextFutureStages.map((stage) => (
            <a href="/ai-roadmap/#future-route">
              <span>{stage.number}</span>
              <strong>{stage.title}</strong>
              <em>{stage.range}</em>
            </a>
          ))}
        </div>
        <div class="route-preview-panel graduation">
          <h3>毕业目标</h3>
          <p>从 {graduationProjects.length} 个综合项目里任选完成 3 个，形成能展示的 AI 项目作品集。</p>
          <a class="text-link" href="/ai-roadmap/#graduation-projects">查看毕业项目</a>
        </div>
      </div>
    </section>

    <section class="journey-note">
      <div class="shell journey-note-inner">
        <span class="journey-note-label">主题</span>
        <p>从“什么是 AI”开始，依次走过机器学习、深度学习、PyTorch 和项目实战。</p>
        <a class="journey-note-link" href="/ai-roadmap/">查看 AI 路线</a>
      </div>
    </section>

    <ProjectSpotlight variant="legacy" headingId="echo-project-legacy-title" />

    <section class="shell section article-section">
      <div class="section-heading">
        <div>
          <h2>最新文章</h2>
          <p>从最近写下来的内容开始，顺着时间往前翻。</p>
        </div>
        <a class="button secondary" href="/rss.xml">RSS 订阅</a>
      </div>
      <div class="post-list">
        {recent.slice(0, 5).map((post) => <PostRow post={post} />)}
      </div>
    </section>
  </main>
</BaseLayout>
