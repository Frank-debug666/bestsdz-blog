---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concepts, getConceptBySlug } from '../../concepts';

export function getStaticPaths() {
  return concepts.map((concept) => ({
    params: { slug: concept.slug },
  }));
}

const { slug } = Astro.params;
const concept = getConceptBySlug(slug ?? '');

if (!concept) {
  return Astro.redirect('/glossary/');
}

const posts = await getCollection('posts', ({ data }) => !data.draft);
const isPost = (post: CollectionEntry<'posts'> | undefined): post is CollectionEntry<'posts'> => post !== undefined;
const relatedPosts = concept.relatedPostIds.map((id) => posts.find((post) => post.id === id)).filter(isPost);
---

<BaseLayout title={`${concept.title} 是什么`} description={concept.summary}>
  <main class="shell page-shell concept-page">
    <article class="concept-detail">
      <a class="text-link" href="/glossary/">返回概念库</a>
      <div class="concept-title-row">
        <span class="eyebrow">{concept.category}</span>
        <h1>{concept.title} 是什么？</h1>
        <p>{concept.summary}</p>
      </div>

      <section class="concept-explain">
        <h2>一句话理解</h2>
        <p>{concept.plain}</p>
      </section>

      {concept.aliases.length > 0 && (
        <section class="concept-aliases" aria-labelledby="concept-aliases-title">
          <h2 id="concept-aliases-title">也常被叫做</h2>
          <div class="post-tags">
            {concept.aliases.map((alias) => <span class="tag soft">{alias}</span>)}
          </div>
        </section>
      )}

      <section class="concept-reading" aria-labelledby="concept-reading-title">
        <h2 id="concept-reading-title">继续阅读</h2>
        <div class="related-reading-grid">
          {relatedPosts.map((post) => (
            <a class="related-reading-card" href={`/posts/${post.id}/`}>
              <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
              <strong>{post.data.title}</strong>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
