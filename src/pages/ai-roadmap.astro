---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const postById = new Map(posts.map((post) => [post.id, post]));

type PostEntry = (typeof posts)[number];

const publishedLessons = [
  'why-start-ai-blog',
  'what-is-neural-network',
  'activation-function',
  'loss-function',
  'cross-entropy-loss',
  'gradient-descent',
  'what-is-tensor',
  'pytorch-linear-layer',
  'pytorch-dataloader',
  'pytorch-training-flow',
]
  .map((id) => postById.get(id))
  .filter((post): post is PostEntry => Boolean(post));

const upcomingLessons = [
  ['2026-06-21', 'MSELoss 详解：回归任务为什么常用均方误差', 'AI 基础'],
  ['2026-06-23', 'SGD 优化器是什么？最基础的参数更新方法', 'AI 基础'],
  ['2026-06-25', 'Adam 优化器为什么这么常用？原理和直觉版解释', 'AI 基础'],
  ['2026-06-28', '反向传播到底在做什么？别再只会背公式了', 'AI 基础'],
  ['2026-06-30', 'Dataset 是什么？为什么训练数据要先封装', 'PyTorch 实战'],
  ['2026-07-02', 'with torch.no_grad 有什么用？验证和推理为什么要关梯度', 'PyTorch 实战'],
  ['2026-07-05', 'PyTorch 怎么用 GPU 训练？从 CPU 到 CUDA 的完整流程', 'PyTorch 实战'],
  ['2026-07-07', '模型怎么保存和加载？state_dict 一次讲明白', 'PyTorch 实战'],
  ['2026-07-09', '训练过程怎么监控？loss、accuracy、学习率应该怎么看', 'PyTorch 实战'],
  ['2026-07-12', '决策边界可视化：怎么真正看懂一个分类模型学到了什么', 'PyTorch 实战'],
  ['2026-07-14', 'Transformer 是什么？为什么它改变了 NLP', 'Transformer 专题'],
  ['2026-07-16', 'Attention 机制是什么？为什么模型开始会看重点', 'Transformer 专题'],
  ['2026-07-19', 'Self-Attention 详解：一句话内部的信息怎么交互', 'Transformer 专题'],
  ['2026-07-21', 'Q、K、V 到底是什么？用最直白的方式解释清楚', 'Transformer 专题'],
  ['2026-07-23', 'Multi-Head Attention 为什么要多头？不是头越多越玄学', 'Transformer 专题'],
  ['2026-07-26', 'Position Encoding 是什么？Transformer 为什么还需要位置', 'Transformer 专题'],
  ['2026-07-28', 'Encoder 结构详解：输入文本是怎么被编码的', 'Transformer 专题'],
  ['2026-07-30', 'Decoder 结构详解：输出文本是怎么一步步生成的', 'Transformer 专题'],
  ['2026-08-02', 'GPT 的工作原理是什么？从 Transformer 到生成模型', 'Transformer 专题'],
  ['2026-08-04', 'Transformer 学习总结：我终于把这一套串起来了', 'Transformer 专题'],
];
---

<BaseLayout
  title="AI 入门路线"
  description="从神经网络、损失函数、梯度下降到 PyTorch 训练流程，按顺序整理 AI 初学者可以持续阅读的学习路线。"
>
  <main class="shell page-shell">
    <section class="page-hero roadmap-hero">
      <span class="eyebrow">AI Learning Roadmap</span>
      <h1>AI 入门路线</h1>
      <p>
        这不是一份堆满术语的清单，而是一条从“模型怎么学习”走到“PyTorch 怎么训练”的路线。先把概念讲清楚，再把代码跑起来。
      </p>
    </section>

    <section class="roadmap-summary" aria-label="路线概览">
      <article>
        <strong>{publishedLessons.length}</strong>
        <span>已发布入门文章</span>
      </article>
      <article>
        <strong>{upcomingLessons.length}</strong>
        <span>后续选题排期</span>
      </article>
      <article>
        <strong>3</strong>
        <span>学习阶段：基础、PyTorch、Transformer</span>
      </article>
    </section>

    <section class="page-section roadmap-section">
      <div class="section-heading">
        <div>
          <h2>先读这 10 篇</h2>
          <p>按顺序读，比单篇随机看更容易把神经网络、训练流程和 PyTorch 对象串起来。</p>
        </div>
        <a class="button secondary" href="/posts/">全部文章</a>
      </div>

      <ol class="lesson-list">
        {publishedLessons.map((post, index) => (
          <li>
            <span class="lesson-index">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              <p>{post.data.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="page-section roadmap-section">
      <div class="section-heading">
        <div>
          <h2>接下来 20 篇</h2>
          <p>后续会从优化器、Dataset、GPU 训练一路写到 Transformer，每篇都尽量保留“概念 + 代码 + 使用场景”。</p>
        </div>
      </div>

      <div class="calendar-list">
        {upcomingLessons.map(([date, title, track]) => (
          <article>
            <time datetime={date}>{date}</time>
            <h3>{title}</h3>
            <span>{track}</span>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
