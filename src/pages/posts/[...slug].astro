---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import AuthorCard from '../../components/AuthorCard.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';
import { getPostPlacement } from '../../learning-path';
import { getCanonicalTags, getRelatedPosts } from '../../content-taxonomy';
import { buildCourseGuide } from '../../course-guide';
import { getConceptsForPost } from '../../concepts';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const isPost = (item: CollectionEntry<'posts'> | undefined): item is CollectionEntry<'posts'> => item !== undefined;
const postById = new Map(posts.map((item) => [item.id, item]));
const currentIndex = posts.findIndex((item) => item.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 ? posts[currentIndex + 1] : undefined;
const tags = getCanonicalTags(post.data.tags);
const relatedPosts = getRelatedPosts(post, posts);
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const date = post.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedDate = (post.data.updatedDate ?? post.data.pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingMinutes = Math.max(1, Math.ceil((post.body ?? '').length / 500));
const placement = getPostPlacement(post.id);
const stagePosts = placement.stage ? placement.stage.postIds.map((id) => postById.get(id)).filter(isPost) : [];
const stageIndex = stagePosts.findIndex((item) => item.id === post.id);
const previousLesson = stageIndex > 0 ? stagePosts[stageIndex - 1] : undefined;
const nextLesson = stageIndex >= 0 ? stagePosts[stageIndex + 1] : undefined;
const postConcepts = getConceptsForPost(post.id, tags, post.data.title, 5);
const courseGuide = buildCourseGuide({
  title: post.data.title,
  description: post.data.description,
  tags,
  stageTitle: placement.stage?.title,
  sectionTitle: placement.section?.title,
  previousTitle: previousLesson?.data.title,
  nextTitle: nextLesson?.data.title,
  concepts: postConcepts,
});
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const articleUrl = new URL(`/posts/${post.id}/`, siteUrl).toString();
const articleImage = post.data.cover ?? '/images/hero-qingdao-harbor.jpg';
const articleImageUrl = new URL(articleImage, siteUrl).toString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: articleImageUrl,
  url: articleUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: siteConfig.author.name,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL(siteConfig.author.avatar, siteUrl).toString(),
    },
  },
  mainEntityOfPage: articleUrl,
  learningResourceType: 'Lesson',
  educationalLevel: placement.stage?.level ?? placement.section?.level,
  teaches: courseGuide.outcomes,
  about: postConcepts.map((concept) => ({
    '@type': 'DefinedTerm',
    name: concept.title,
    description: concept.summary,
    url: new URL(`/glossary/${concept.slug}/`, siteUrl).toString(),
  })),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={articleImage}
  type="article"
  structuredData={articleSchema}
>
  <main class="shell page-shell article-shell">
    <header class="article-hero">
      <div class="article-meta-line">
        <time class="post-meta" datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span>{readingMinutes} 分钟读完</span>
        <span>最后更新：{updatedDate}</span>
        {placement.section && <span>{placement.section.title}</span>}
        {placement.stage && <span>{placement.stage.level}</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
      <div class="post-tags">
        {tags.map((tag) => <a class="tag soft" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
      </div>
      {placement.stage && placement.lessonNumber && (
        <a class="article-route-link" href={`/ai-roadmap/#${placement.stage.id}`}>
          学习路线：{placement.stage.title} · 第 {placement.lessonLabel ?? placement.globalLessonNumber ?? placement.lessonNumber} 课
        </a>
      )}
    </header>

    {post.data.cover && (
      <figure class="article-cover">
        <div class="article-cover-frame">
          {placement.stage && (
            <span class="article-cover-lesson-badge">
              第 {placement.lessonLabel ?? placement.globalLessonNumber ?? placement.lessonNumber} 课
            </span>
          )}
          <img
            src={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            width="1680"
            height="1120"
          />
        </div>
      </figure>
    )}

    {placement.stage && (
      <section class="learning-context" aria-labelledby="learning-context-title">
        <div>
          <span class="eyebrow">Learning Path</span>
          <h2 id="learning-context-title">{placement.stage.title}</h2>
          <p>{placement.stage.description}</p>
          <p class="learning-outcome"><strong>学完本阶段你能做到：</strong>{placement.stage.outcome}</p>
          <p class="learning-mode"><strong>推荐读法：</strong>{placement.stage.readingMode}</p>
          <a class="text-link" href={`/ai-roadmap/#${placement.stage.id}`}>
            查看完整阶段 · {stagePosts.length} 篇
          </a>
        </div>
        <div class="learning-context-links">
          {previousLesson ? (
            <a href={`/posts/${previousLesson.id}/`}>
              <span>上一课</span>
              <strong>{previousLesson.data.title}</strong>
            </a>
          ) : (
            <span class="learning-context-placeholder">这是本阶段第一课</span>
          )}
          {nextLesson ? (
            <a href={`/posts/${nextLesson.id}/`}>
              <span>下一课</span>
              <strong>{nextLesson.data.title}</strong>
            </a>
          ) : (
            <span class="learning-context-placeholder">本阶段已读完</span>
          )}
        </div>
      </section>
    )}

    <section class="course-guide" aria-labelledby="course-guide-title">
      <div class="course-guide-heading">
        <span class="eyebrow">Lesson Guide</span>
        <h2 id="course-guide-title">这一课怎么学</h2>
        <p>先看目标，再带着问题读正文。读完后用练习确认自己真的理解了。</p>
      </div>
      <div class="course-guide-grid">
        <article class="course-guide-card">
          <h3>本节你会学到</h3>
          <ul>
            {courseGuide.outcomes.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="course-guide-card">
          <h3>前置知识</h3>
          <ul>
            {courseGuide.prerequisites.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="course-guide-card wide">
          <h3>概念回顾</h3>
          <ul>
            {courseGuide.conceptReview.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="course-guide-card wide">
          <h3>核心概念</h3>
          {courseGuide.concepts.length > 0 ? (
            <div class="concept-chip-list">
              {courseGuide.concepts.map((concept) => (
                <a href={`/glossary/${concept.slug}/`}>
                  <strong>{concept.title}</strong>
                  <span>{concept.summary}</span>
                </a>
              ))}
            </div>
          ) : (
            <p>这篇文章偏记录型内容，可以重点关注正文里的方法和复盘。</p>
          )}
        </article>
        <article class="course-guide-card">
          <h3>常见误区</h3>
          <ul>
            {courseGuide.pitfalls.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="course-guide-card">
          <h3>课后练习</h3>
          <ul>
            {courseGuide.exercises.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="course-guide-card wide">
          <h3>自检练习与参考答案</h3>
          <div class="self-check-list">
            {courseGuide.selfCheck.map((item, index) => (
              <details>
                <summary>{index + 1}. {item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </article>
      </div>
      <p class="course-next-note">{courseGuide.nextSuggestion}</p>
    </section>

    <div class="article-layout">
      {tocHeadings.length > 0 && (
        <aside class="article-toc" aria-label="文章目录">
          <strong>目录</strong>
          <nav>
            {tocHeadings.map((heading) => (
              <a class={`toc-depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}

      <article class="prose article-prose">
        <Content />
      </article>
    </div>

    {relatedPosts.length > 0 && (
      <section class="related-reading" aria-labelledby="related-reading-title">
        <div>
          <span class="eyebrow">Next</span>
          <h2 id="related-reading-title">继续阅读</h2>
          <p>根据这篇文章的主题和标签，挑几篇适合顺着读下去的内容。</p>
        </div>
        <div class="related-reading-grid">
          {relatedPosts.map((item) => (
            <a class="related-reading-card" href={`/posts/${item.id}/`}>
              <span>{item.data.pubDate.toLocaleDateString('zh-CN')}</span>
              <strong>{item.data.title}</strong>
              <p>{item.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <AuthorCard />

    {(newerPost || olderPost) && (
      <nav class="post-nav" aria-label="上一篇和下一篇">
        {newerPost ? (
          <a class="post-nav-card" href={`/posts/${newerPost.id}/`}>
            <span>上一篇</span>
            <strong>{newerPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-nav-card is-empty" aria-hidden="true"></span>
        )}
        {olderPost ? (
          <a class="post-nav-card" href={`/posts/${olderPost.id}/`}>
            <span>下一篇</span>
            <strong>{olderPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-nav-card is-empty" aria-hidden="true"></span>
        )}
      </nav>
    )}
    <GiscusComments />
  </main>

  <script is:inline>
    const codeBlocks = Array.from(document.querySelectorAll('.prose pre'));

    codeBlocks.forEach((block) => {
      if (block.querySelector('.copy-code-button')) {
        return;
      }

      const code = block.querySelector('code');
      if (!code) {
        return;
      }

      const button = document.createElement('button');
      button.className = 'copy-code-button';
      button.type = 'button';
      button.textContent = '复制';
      button.setAttribute('aria-label', '复制代码');

      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          button.textContent = '已复制';
          button.classList.add('is-copied');
          window.setTimeout(() => {
            button.textContent = '复制';
            button.classList.remove('is-copied');
          }, 1600);
        } catch {
          button.textContent = '复制失败';
          window.setTimeout(() => {
            button.textContent = '复制';
          }, 1600);
        }
      });

      block.append(button);
    });
  </script>
</BaseLayout>
