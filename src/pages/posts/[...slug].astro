---
import { getCollection, render } from 'astro:content';
import AuthorCard from '../../components/AuthorCard.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';
import { getPostPlacement } from '../../learning-path';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIndex = posts.findIndex((item) => item.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 ? posts[currentIndex + 1] : undefined;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const date = post.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingMinutes = Math.max(1, Math.ceil((post.body ?? '').length / 500));
const placement = getPostPlacement(post.id);
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const articleUrl = new URL(`/posts/${post.id}/`, siteUrl).toString();
const articleImage = post.data.cover ?? '/images/hero-qingdao-harbor.jpg';
const articleImageUrl = new URL(articleImage, siteUrl).toString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: articleImageUrl,
  url: articleUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: siteConfig.author.name,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL(siteConfig.author.avatar, siteUrl).toString(),
    },
  },
  mainEntityOfPage: articleUrl,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={articleImage}
  type="article"
  structuredData={articleSchema}
>
  <main class="shell page-shell article-shell">
    <header class="article-hero">
      <div class="article-meta-line">
        <time class="post-meta" datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span>{readingMinutes} 分钟读完</span>
        {placement.section && <span>{placement.section.title}</span>}
        {placement.stage && <span>{placement.stage.level}</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
      <div class="post-tags">
        {post.data.tags.map((tag) => <a class="tag soft" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
      </div>
      {placement.stage && placement.lessonNumber && (
        <a class="article-route-link" href={`/ai-roadmap/#${placement.stage.id}`}>
          学习路线：{placement.stage.title} · 第 {placement.lessonNumber} 课
        </a>
      )}
    </header>

    {post.data.cover && (
      <figure class="article-cover">
        <div class="article-cover-frame">
          <img
            src={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            width="1680"
            height="1120"
          />
        </div>
      </figure>
    )}

    <div class="article-layout">
      {tocHeadings.length > 0 && (
        <aside class="article-toc" aria-label="文章目录">
          <strong>目录</strong>
          <nav>
            {tocHeadings.map((heading) => (
              <a class={`toc-depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}

      <article class="prose article-prose">
        <Content />
      </article>
    </div>

    <AuthorCard />

    {(newerPost || olderPost) && (
      <nav class="post-nav" aria-label="上一篇和下一篇">
        {newerPost ? (
          <a class="post-nav-card" href={`/posts/${newerPost.id}/`}>
            <span>上一篇</span>
            <strong>{newerPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-nav-card is-empty" aria-hidden="true"></span>
        )}
        {olderPost ? (
          <a class="post-nav-card" href={`/posts/${olderPost.id}/`}>
            <span>下一篇</span>
            <strong>{olderPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-nav-card is-empty" aria-hidden="true"></span>
        )}
      </nav>
    )}
    <GiscusComments />
  </main>

  <script is:inline>
    const codeBlocks = Array.from(document.querySelectorAll('.prose pre'));

    codeBlocks.forEach((block) => {
      if (block.querySelector('.copy-code-button')) {
        return;
      }

      const code = block.querySelector('code');
      if (!code) {
        return;
      }

      const button = document.createElement('button');
      button.className = 'copy-code-button';
      button.type = 'button';
      button.textContent = '复制';
      button.setAttribute('aria-label', '复制代码');

      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          button.textContent = '已复制';
          button.classList.add('is-copied');
          window.setTimeout(() => {
            button.textContent = '复制';
            button.classList.remove('is-copied');
          }, 1600);
        } catch {
          button.textContent = '复制失败';
          window.setTimeout(() => {
            button.textContent = '复制';
          }, 1600);
        }
      });

      block.append(button);
    });
  </script>
</BaseLayout>
